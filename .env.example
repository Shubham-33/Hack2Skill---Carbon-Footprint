# Copy to .env and fill in. .env is gitignored.

# --- Anthropic (orchestration / any LLM calls in scripts) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Email (send_email.py) ---
# Uses SMTP. For Gmail, create an App Password (not your login password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=you@gmail.com

# --- Google Sheets (read_sheet.py / update_sheet.py) ---
# Path to a service-account JSON, OR use credentials.json + token.json OAuth flow.
GOOGLE_SERVICE_ACCOUNT_JSON=credentials.json

# --- Slack (webhook activity stream) ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- Carbon data API (example domain tool) ---
# https://www.climatiq.io — free tier available
CLIMATIQ_API_KEY=
