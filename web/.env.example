# Copy to .env for local dev (gitignored). Production uses Secret Manager.

# --- NVIDIA NIM (OpenAI-compatible) — the LLM ---
# Get a free key at https://build.nvidia.com (key looks like nvapi-...)
NVIDIA_API_KEY=nvapi-...
# Optional: override the model. Default is a fast, capable instruct model.
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# --- Google Sheets ledger (streak / savings / Grove) ---
# Path to a service-account JSON. Share the target sheet with its client_email.
GOOGLE_SERVICE_ACCOUNT_JSON=credentials.json
SPROUT_SHEET_ID=

# --- App config ---
# Comma-free; max characters accepted from the activity input (security guard)
MAX_INPUT_CHARS=600
